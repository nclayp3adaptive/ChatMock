# Port
PORT=8000

# Bind only to loopback by default so the API is private unless you intentionally proxy it.
CHATMOCK_BIND_IP=127.0.0.1

# Image tag for the locally built container
CHATMOCK_IMAGE=chatmock:local

# Host directory that contains auth.json
CHATMOCK_DATA_DIR=./data

# show request/stream logs
VERBOSE=false

# OAuth client id (modify only if you know what you're doing)
# CHATGPT_LOCAL_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann

# Reasoning controls
CHATGPT_LOCAL_REASONING_EFFORT=xhigh        # none|minimal|low|medium|high|xhigh
CHATGPT_LOCAL_REASONING_SUMMARY=detailed    # auto|concise|detailed|none
CHATGPT_LOCAL_REASONING_COMPAT=think-tags   # legacy|o3|think-tags|current
CHATGPT_LOCAL_EXPOSE_REASONING_MODELS=false

# Enable default web search tool
CHATGPT_LOCAL_ENABLE_WEB_SEARCH=false

# Force a specific model name
CHATGPT_LOCAL_DEBUG_MODEL=gpt-5.4
